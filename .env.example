# No API keys required — arXiv and Semantic Scholar are public APIs.
#
# Optional: override default output paths by setting these env vars
# and passing them via CLI args:
#
#   python3 scripts/arxiv_downloader.py \
#     --output /path/to/your/vault/arxiv_pdfs \
#     --metadata-dir /path/to/your/vault/10-Knowledge/metadata
#
# VAULT_PATH=/path/to/your/obsidian/vault
